# Worker database connection (used to read role + role-match context)
# Use DIRECT_URL for direct connections (psycopg doesn't support pgbouncer parameter)
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/aegishire

# Gap report LLM provider preference:
# 1. If GROQ_API_KEY is set -> tries Groq with GROQ_MODEL_NAME
# 2. Else if OLLAMA_BASE_URL is set -> tries Ollama with OLLAMA_MODEL_NAME
# 3. Else uses LLM_PROVIDER setting with LLM_MODEL_NAME

LLM_PROVIDER=ollama
LLM_MODEL_NAME=qwen3.5:4b

# Provider-specific model names (optional; falls back to LLM_MODEL_NAME if not set)
GROQ_MODEL_NAME=mixtral-8x7b-32768
OLLAMA_MODEL_NAME=qwen3.5:4b
OLLAMA_BASE_URL=http://localhost:11434

# Optional provider API keys (only required if using that provider)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# Local Neo4j Docker environment (matches infra/docker-compose.yml)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# CV parser AI source (independent of gap report provider selection):
# - If GROQ_API_KEY is set => Groq parsing mode
# - Else if OLLAMA_BASE_URL + (OLLAMA_MODEL_NAME or LLM_MODEL_NAME) => Ollama parsing mode
# - Else => regex fallback mode

