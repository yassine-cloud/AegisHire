# Use the Supabase Postgres connection string (recommended for team consistency).
# Keep apps/api/.env and packages/db/.env pointed to the same database.
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require"

# Optional direct connection URL (recommended for Prisma migrations/introspection).
# Example host typically uses AWS pooler endpoint and port 6543 or direct 5432 depending on Supabase docs.
DIRECT_URL=""

# Supabase project URL (e.g. https://<project-ref>.supabase.co)
SUPABASE_URL=""

# Public anon key from Project Settings -> API
SUPABASE_ANON_KEY=""

# Optional explicit JWKS endpoint for token verification.
# If empty, build it from SUPABASE_URL + /auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=""

# Optional explicit JWT issuer.
# If empty, use SUPABASE_URL + /auth/v1
SUPABASE_JWT_ISSUER=""

# Optional explicit JWT audience.
# Defaults to "authenticated"
SUPABASE_JWT_AUDIENCE="authenticated"

# Optional: local API base URL used by .http test files
API_BASE_URL="http://localhost:3001"

# Redis cache
REDIS_URL="redis://localhost:6379"

# Python worker base URL
WORKER_BASE_URL="http://localhost:8000"

# Worker-side LLM values (documented here for local stack convenience)
LLM_PROVIDER="ollama"
LLM_MODEL_NAME="llama3.1:8b"
OLLAMA_BASE_URL="http://localhost:11434"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""
GROQ_API_KEY=""
