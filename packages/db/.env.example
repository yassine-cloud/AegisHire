# Use the same Supabase Postgres connection string as apps/api/.env.
# Example format: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require"

# Optional direct URL for Prisma migrations/introspection.
DIRECT_URL=""